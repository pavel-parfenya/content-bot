DEEPSEEK_API_KEY=
BOT_TOKEN=
CHANEL_ID=@chanel
ADMIN_ID=
POST_FREQ_MINUTES=00
# Локально: localhost. На Render: Internal Database URL из панели PostgreSQL (не localhost; порт в строке обычно 5432).
DATABASE_URL=postgresql://contentbot:contentbot@localhost:5432/contentbot
# Отдельная схема в общей БД (таблицы content_bot.news и т.д.). По умолчанию: content_bot
DATABASE_SCHEMA=content_bot
