DEEPSEEK_API_KEY=
BOT_TOKEN=
CHANEL_ID=@chanel
ADMIN_ID=
# polling (по умолчанию) | webhook
MODE=polling
# При MODE=webhook: полный HTTPS URL и path для POST (как у Telegram). WEBHOOK_SECRET — опционально (1–256 символов).
# WEBHOOK_URL=https://your-app.onrender.com/telegram
# WEBHOOK_SECRET=
# PORT на Render задаётся платформой; приложение слушает 0.0.0.0:PORT (webhook или health при polling).
POST_FREQ_MINUTES=00
# Локально без Docker: localhost. Docker Compose: строку ниже можно не задавать — в docker-compose.yml
# уже подставлен хост `db`. На Render: Internal Database URL из панели PostgreSQL.
DATABASE_URL=postgresql://contentbot:contentbot@localhost:5432/contentbot
# Отдельная схема в общей БД (таблицы content_bot.news и т.д.). По умолчанию: content_bot
DATABASE_SCHEMA=content_bot
