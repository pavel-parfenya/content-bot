{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "baseUrl": "src",
    "paths": {
      "config": ["config"],
      "bot": ["bot"],
      "db/*": ["db/*"],
      "commands/*": ["commands/*"],
      "handlers/*": ["handlers/*"],
      "services/*": ["services/*"],
      "utils/*": ["utils/*"],
      "middleware/*": ["middleware/*"],
      "server/*": ["server/*"]
    }
  },
  "include": ["src"]
}

